# Fortnox adapter example configuration.
# Copy values into an ignored local env file. Never commit real credentials.

FORTNOX_ENVIRONMENT=sandbox
FORTNOX_BASE_URL=https://api.fortnox.se/3
FORTNOX_DRY_RUN=true
# Compatibility flag only. Current adapter code rejects every external write.
FORTNOX_ALLOW_DRAFT_WRITES=false
FORTNOX_ALLOW_SENSITIVE_READS=false
FORTNOX_TIMEOUT_SECONDS=20
FORTNOX_ACCESS_TOKEN=
